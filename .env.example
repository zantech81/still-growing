# Still Growing — environment variables
# This is a SEPARATE Supabase project and SEPARATE keys from Chegu.my.
# Never copy Chegu's keys here.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mux — use a dedicated key/environment for Still Growing, not Chegu's.
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Systeme.io — dedicated key for Still Growing (marketing-capture only,
# not used for purchase verification per the honor-system decision).
SYSTEME_API_KEY=

# SendGrid — dedicated key scoped for Still Growing.
SENDGRID_API_KEY=

# Support inbox surfaced to readers whose reflection reads as product
# feedback/complaint rather than a chapter reflection (see lib/moderation.ts).
SUPPORT_EMAIL=

NEXT_PUBLIC_SITE_URL=https://stillgrowing.co

# Shared secret Vercel Cron sends as "Authorization: Bearer <value>" when it
# invokes /api/cron/birthdays (see vercel.json). Without this set, the route
# returns 401 for every request, including Vercel's own cron invocations.
CRON_SECRET=
